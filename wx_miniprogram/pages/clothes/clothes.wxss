/* pages/clothes/clothes.wxss - 晾衣架控制页（蓝白清新配色） */

/* ============ 页面容器 ============ */
.page-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #e8f0fe 0%, #f0f5ff 40%, #f5f8ff 100%);
  padding: 20rpx 30rpx;
  box-sizing: border-box;
}

/* ============ 警告横幅 ============ */
.warning-banner {
  display: flex;
  align-items: center;
  padding: 20rpx 30rpx;
  margin-bottom: 20rpx;
  border-radius: 20rpx;
  background: #fff1f0;
  border: 1rpx solid #ffccc7;
  opacity: 0;
  transform: translateY(-30rpx);
  transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  pointer-events: none;
}

.warning-show {
  opacity: 1;
  transform: translateY(0);
  animation: warningShake 0.5s ease-in-out;
}

@keyframes warningShake {
  0%, 100% { transform: translateX(0); }
  10%, 50%, 90% { transform: translateX(-6rpx); }
  30%, 70% { transform: translateX(6rpx); }
}

.warning-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
  animation: warningPulse 1s ease-in-out infinite;
}

@keyframes warningPulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.2); }
}

.warning-content {
  display: flex;
  flex-direction: column;
}

.warning-title {
  font-size: 26rpx;
  color: #cf1322;
  font-weight: 600;
}

.warning-text {
  font-size: 22rpx;
  color: #ff4d4f;
  margin-top: 4rpx;
}

/* ============ 状态栏 ============ */
.status-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 18rpx 30rpx;
  margin-bottom: 30rpx;
  border-radius: 40rpx;
  background: #ffffff;
  box-shadow: 0 4rpx 20rpx rgba(74, 144, 217, 0.08);
  transition: all 0.5s ease;
}

.status-bar.connected {
  border: 1rpx solid rgba(74, 144, 217, 0.15);
}

.status-bar.disconnected {
  border: 1rpx solid rgba(245, 34, 45, 0.15);
}

.status-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  margin-right: 16rpx;
}

.dot-online {
  background: #52c41a;
  box-shadow: 0 0 12rpx rgba(82, 196, 26, 0.4);
  animation: dotPulse 2s ease-in-out infinite;
}

.dot-offline {
  background: #f5222d;
  box-shadow: 0 0 10rpx rgba(245, 34, 45, 0.3);
}

.status-text {
  font-size: 26rpx;
  color: #4a5568;
  flex: 1;
}

.reconnect-btn {
  padding: 8rpx 24rpx;
  border-radius: 30rpx;
  background: rgba(74, 144, 217, 0.1);
  border: 1rpx solid rgba(74, 144, 217, 0.25);
}

.reconnect-btn text {
  font-size: 24rpx;
  color: #4a90d9;
}

.connecting-text text {
  font-size: 24rpx;
  color: #fa8c16;
  animation: blink 1s ease-in-out infinite;
}

@keyframes dotPulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.6; transform: scale(1.3); }
}

@keyframes blink {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.4; }
}

/* ============ 控制区域 ============ */
.control-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 40rpx;
}

/* ============ 分区标题 ============ */
.section {
  width: 100%;
  margin: 0 auto 40rpx auto;
  padding: 30rpx;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 4rpx 20rpx rgba(74, 144, 217, 0.06);
  border: 1rpx solid #e8edf5;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.section-title {
  font-size: 28rpx;
  color: #4a5568;
  text-align: center;
  margin-bottom: 24rpx;
  letter-spacing: 4rpx;
  font-weight: 600;
}

/* ============ 晾衣架状态 ============ */
.rack-status {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 50rpx;
}

.status-indicator {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
  transition: all 0.5s ease;
}

.indicator-on {
  background: rgba(82, 196, 26, 0.08);
  border: 2rpx solid rgba(82, 196, 26, 0.25);
}

.indicator-off {
  background: #f5f7fa;
  border: 2rpx solid #dce6f5;
}

.indicator-ring {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.indicator-on .indicator-ring {
  box-shadow: 0 0 30rpx rgba(82, 196, 26, 0.2);
  animation: ringPulse 2s ease-in-out infinite;
}

.indicator-off .indicator-ring {
  box-shadow: none;
}

@keyframes ringPulse {
  0%, 100% { box-shadow: 0 0 20rpx rgba(82, 196, 26, 0.15); }
  50% { box-shadow: 0 0 40rpx rgba(82, 196, 26, 0.35); }
}

.indicator-core {
  width: 30rpx;
  height: 30rpx;
  border-radius: 50%;
  transition: all 0.5s ease;
}

.indicator-on .indicator-core {
  background: #52c41a;
  box-shadow: 0 0 16rpx rgba(82, 196, 26, 0.5);
}

.indicator-off .indicator-core {
  background: #c4cdd5;
}

.status-label {
  font-size: 32rpx;
  color: #4a5568;
  font-weight: 500;
  letter-spacing: 4rpx;
}

/* ============ 晾衣架可视化 ============ */
.rack-visual {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 60rpx;
  width: 100%;
  transition: transform 0.8s cubic-bezier(0.4, 0, 0.2, 1);
}

.rack-up {
  transform: translateY(-40rpx);
}

.rack-down {
  transform: translateY(0rpx);
}

.rack-bar {
  width: 320rpx;
  height: 8rpx;
  background: linear-gradient(90deg, transparent, #c4cdd5, transparent);
  border-radius: 4rpx;
  margin-bottom: 16rpx;
}

.rack-body {
  display: flex;
  gap: 40rpx;
  padding: 16rpx 40rpx;
  background: #f5f7fa;
  border-radius: 16rpx;
  border: 1rpx solid #e8edf5;
}

.rack-line {
  width: 4rpx;
  height: 80rpx;
  background: #dce6f5;
  border-radius: 2rpx;
  transition: all 0.8s ease;
}

.rack-down .rack-line {
  height: 160rpx;
  background: rgba(74, 144, 217, 0.25);
}

.rack-hook {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 3rpx solid #dce6f5;
  margin-top: 12rpx;
  transition: all 0.8s ease;
}

.rack-down .rack-hook {
  border-color: rgba(74, 144, 217, 0.4);
  box-shadow: 0 0 16rpx rgba(74, 144, 217, 0.15);
}

/* ============ 窗户状态 ============ */
.window-status {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 30rpx;
  padding: 16rpx 30rpx;
  border-radius: 30rpx;
  background: #f5f7fa;
  border: 1rpx solid #e8edf5;
}

.window-label {
  font-size: 26rpx;
  color: #6b7d95;
}

.window-value {
  font-size: 28rpx;
  color: #4a5568;
  font-weight: 500;
}

/* ============ 控制按钮组 ============ */
.btn-group {
  display: flex;
  justify-content: center;
  gap: 24rpx;
  margin-bottom: 10rpx;
  width: 100%;
}

.control-btn {
  position: relative;
  width: 280rpx;
  height: 96rpx;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  transition: transform 0.15s ease, box-shadow 0.15s ease;
}

.control-btn:active {
  transform: scale(0.95);
}

.btn-extend {
  background: linear-gradient(135deg, #4a90d9, #7bb3f0);
  box-shadow: 0 6rpx 24rpx rgba(74, 144, 217, 0.25);
}

.btn-retract {
  background: linear-gradient(135deg, #ff7875, #f5222d);
  box-shadow: 0 6rpx 24rpx rgba(245, 34, 45, 0.2);
}

.btn-pressed {
  transform: scale(0.95) !important;
  opacity: 0.75;
}

.btn-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  opacity: 0.05;
}

.btn-content {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.btn-icon {
  font-size: 32rpx;
}

.btn-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #ffffff;
  letter-spacing: 2rpx;
}

/* 按钮光晕动画 */
.btn-glow-ring {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 0;
  height: 0;
  border-radius: 50%;
  transform: translate(-50%, -50%);
  pointer-events: none;
  animation: btnGlow 2.5s ease-out infinite;
}

.btn-extend .btn-glow-ring {
  box-shadow: 0 0 0 0 rgba(74, 144, 217, 0.3);
}

.btn-retract .btn-glow-ring {
  box-shadow: 0 0 0 0 rgba(245, 34, 45, 0.3);
}

@keyframes btnGlow {
  0% {
    width: 50rpx;
    height: 50rpx;
    opacity: 0.5;
  }
  100% {
    width: 280rpx;
    height: 280rpx;
    opacity: 0;
  }
}

/* ============ 红外传感器状态 ============ */
.ir-sensor-status {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx 30rpx;
  margin-top: 10rpx;
  border-radius: 30rpx;
  background: #ffffff;
  box-shadow: 0 4rpx 20rpx rgba(74, 144, 217, 0.06);
  border: 1rpx solid #e8edf5;
}

.ir-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  margin-right: 14rpx;
  transition: all 0.3s ease;
}

.ir-idle {
  background: #52c41a;
  box-shadow: 0 0 10rpx rgba(82, 196, 26, 0.35);
}

.ir-active {
  background: #f5222d;
  box-shadow: 0 0 14rpx rgba(245, 34, 45, 0.45);
  animation: irBlink 0.5s ease-in-out infinite;
}

@keyframes irBlink {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.3; }
}

.ir-text {
  font-size: 24rpx;
  color: #6b7d95;
}
